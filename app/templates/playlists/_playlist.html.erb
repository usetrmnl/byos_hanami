<li id="<%= playlist.id %>" class="playlist">
  <h2 class="label"><%= playlist.label %></h2>
  <h3 class="name"><%= playlist.name %></h2>
  <%= tag.span human_at(playlist.created_at) %>
  <%= tag.span human_at(playlist.updated_at) %>

  <div class="actions">
    <a href="<%= routes.path :playlist_mirror_edit, id: playlist.id %>"
       hx-get="<%= routes.path :playlist_mirror_edit, id: playlist.id %>"
       hx-target="closest .page-playlists"
       hx-swap="outerHTML"
       hx-push-url="true">
      Mirror
    </a>

    <a href="/playlists/<%= "#{playlist.id}/edit" %>"
       hx-get="/playlists/<%= "#{playlist.id}/edit" %>"
       hx-target="closest .page-playlists"
       hx-swap="outerHTML"
       hx-push-url="true">
      Edit
    </a>

    <a href="/playlist/<%= playlist.id %>"
       class="link-cancel"
       hx-delete="/playlists/<%= playlist.id %>"
       hx-confirm="Are you sure you want to delete this playlist?"
       hx-target="closest .playlist"
       hx-swap="outerHTML">
      Delete
    </a>
  </div>
</li>
