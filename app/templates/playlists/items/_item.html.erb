<li id="<%= item.id %>" class="item">
  <img src="<%= item.screen.image_uri %>" loading="lazy" width="200" height="120">

  <div class="actions">
    <a href="/items/<%= "#{item.id}/edit" %>"
       hx-get="/items/<%= "#{item.id}/edit" %>"
       hx-target="closest .page-items"
       hx-swap="outerHTML"
       hx-push-url="true">
      Edit
    </a>

    <a href="/item/<%= item.id %>"
       class="link-cancel"
       hx-delete="/items/<%= item.id %>"
       hx-confirm="Are you sure you want to delete this item?"
       hx-target="closest .item"
       hx-swap="outerHTML">
      Delete
    </a>
  </div>
</li>
